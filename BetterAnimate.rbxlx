			jump = 	{ { Id = "rbxassetid://125750702", Weight = 10 } }, 
			fall = 	{ { Id = "rbxassetid://180436148", Weight = 10 } }, 
			climb = { { Id = "rbxassetid://180436334", Weight = 10 } }, 
			sit = 	{ { Id = "rbxassetid://178130996", Weight = 10 } },	
