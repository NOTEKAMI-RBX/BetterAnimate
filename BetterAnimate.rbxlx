			jump = 	{ { Id = "rbxassetid://507765000", Weight = 10 } }, 
			fall = 	{ { Id = "rbxassetid://507767968", Weight = 10 } }, 
			climb = { { Id = "rbxassetid://507765644", Weight = 10 } }, 
