						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">7f4f445f1374609a09dd257200000a19</UniqueId>
						<string name="Name">Destroyer</string>
						<int64 name="SourceAssetId">-1</int64>
